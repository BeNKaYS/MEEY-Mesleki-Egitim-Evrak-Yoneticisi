<UserControl x:Class="MEEY.Controls.VeriGirisi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sol Taraf - Veri Girişi Alanı -->
        <StackPanel Grid.Column="0">
            
            <!-- Form Alanları -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Öğrenci Adı -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                          Text="Öğrenci Adı:" 
                          VerticalAlignment="Center"
                          Margin="0,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                        Height="30"
                        Margin="0,5"
                        Padding="8,5"
                        FontSize="13"/>
                
                <!-- Öğrenci Soyadı -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                          Text="Öğrenci Soyadı:" 
                          VerticalAlignment="Center"
                          Margin="0,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                        Height="30"
                        Margin="0,5"
                        Padding="8,5"
                        FontSize="13"/>
                
                <!-- Sınıf -->
                <TextBlock Grid.Row="2" Grid.Column="0" 
                          Text="Sınıf:" 
                          VerticalAlignment="Center"
                          Margin="0,5"/>
                <ComboBox Grid.Row="2" Grid.Column="1" 
                         Height="30"
                         Margin="0,5"
                         Padding="8,5"
                         FontSize="13">
                    <ComboBoxItem Content="9. Sınıf"/>
                    <ComboBoxItem Content="10. Sınıf"/>
                    <ComboBoxItem Content="11. Sınıf"/>
                    <ComboBoxItem Content="12. Sınıf"/>
                </ComboBox>
                
                <!-- Bölüm -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                          Text="Bölüm:" 
                          VerticalAlignment="Center"
                          Margin="0,5"/>
                <TextBox Grid.Row="3" Grid.Column="1" 
                        Height="30"
                        Margin="0,5"
                        Padding="8,5"
                        FontSize="13"/>
                
                <!-- Butonlar -->
                <StackPanel Grid.Row="4" Grid.Column="1" 
                           Orientation="Horizontal"
                           HorizontalAlignment="Right"
                           Margin="0,15,0,0">
                    <Button Content="Kaydet" 
                           Width="90" Height="32"
                           Background="#27AE60"
                           Foreground="White"
                           BorderThickness="0"
                           Margin="5,0"
                           Cursor="Hand"/>
                    <Button Content="Temizle" 
                           Width="90" Height="32"
                           Background="#95A5A6"
                           Foreground="White"
                           BorderThickness="0"
                           Margin="5,0"
                           Cursor="Hand"/>
                </StackPanel>
                
            </Grid>
        </StackPanel>
        
        <!-- Ayırıcı Çizgi -->
        <Border Grid.Column="1" 
               Width="1" 
               Background="#E0E0E0"
               Margin="10,0"/>
        
        <!-- Sağ Taraf - Bilgilendirme -->
        <StackPanel Grid.Column="2" 
                   VerticalAlignment="Top">
            <TextBlock Text="Bilgilendirme" 
                      Style="{StaticResource ModuleTitle}"
                      FontSize="14"/>
            <TextBlock Style="{StaticResource ModuleDescription}"
                      FontSize="11">
                <Run Text="Bu modülde öğrenci bilgilerini sisteme girebilirsiniz."/>
                <LineBreak/><LineBreak/>
                <Run Text="• Tüm alanları eksiksiz doldurunuz"/>
                <LineBreak/>
                <Run Text="• Öğrenci adı ve soyadı zorunludur"/>
                <LineBreak/>
                <Run Text="• Sınıf seçimi yapılmalıdır"/>
                <LineBreak/>
                <Run Text="• Kaydet butonuna basarak işlemi tamamlayın"/>
            </TextBlock>
        </StackPanel>
        
    </Grid>
    
</UserControl>
