<UserControl x:Class="MEEY.Controls.MetinEditorHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#E6FFFFFF"
             Loaded="UserControl_Loaded">
    <Grid>
        <Border CornerRadius="10" Background="#E6F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" Padding="4" Panel.ZIndex="1">
            <wv2:WebView2 x:Name="EditorWebView" WebMessageReceived="EditorWebView_WebMessageReceived"/>
        </Border>
        <wv2:WebView2 x:Name="HiddenWebView" Panel.ZIndex="0" Visibility="Hidden" IsHitTestVisible="False" Width="1" Height="1"/>
    </Grid>
</UserControl>
