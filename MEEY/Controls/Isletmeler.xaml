<UserControl x:Class="MEEY.Controls.Isletmeler"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Form Alanı -->
        <StackPanel Grid.Row="0" Margin="15">
            
            <!-- İşletme Adı -->
            <TextBlock Text="İşletme Adı:" FontSize="12" Margin="0,5,0,2"/>
            <TextBox x:Name="txtIsletmeAdi" Height="30" FontSize="12"/>
            
            <!-- Telefon -->
            <TextBlock Text="Telefon:" FontSize="12" Margin="0,10,0,2"/>
            <TextBox x:Name="txtTelefon" Height="30" FontSize="12"/>
            
            <!-- Adres -->
            <TextBlock Text="Adres:" FontSize="12" Margin="0,10,0,2"/>
            <TextBox x:Name="txtAdres" Height="60" FontSize="12" 
                    TextWrapping="Wrap" AcceptsReturn="True" 
                    VerticalScrollBarVisibility="Auto"/>
            
            <!-- Butonlar -->
            <UniformGrid Rows="1" Columns="4" Margin="0,15,0,0" Height="35">
                <Button Content="➕ Yeni" Margin="0,0,5,0" 
                       Background="#27AE60" Foreground="White" 
                       BorderThickness="0" Cursor="Hand"
                       Click="BtnYeni_Click"/>
                <Button Content="🗑️ Sil" Margin="5,0" 
                       Background="#E74C3C" Foreground="White" 
                       BorderThickness="0" Cursor="Hand"
                       Click="BtnSil_Click"/>
                <Button Content="🗑️ Tümünü Sil" Margin="5,0" 
                       Background="#C0392B" Foreground="White" 
                       BorderThickness="0" Cursor="Hand"
                       Click="BtnTumunuSil_Click"/>
                <Button Content="💾 Kaydet" Margin="5,0,0,0" 
                       Background="#3498DB" Foreground="White" 
                       BorderThickness="0" Cursor="Hand"
                       Click="BtnKaydet_Click"/>
            </UniformGrid>
            
        </StackPanel>
        
        <!-- DataGrid -->
        <DataGrid x:Name="dgIsletmeler" 
                 Grid.Row="1" 
                 Margin="15,0,15,15"
                 AutoGenerateColumns="False"
                 CanUserAddRows="False"
                 SelectionMode="Single"
                 SelectionChanged="DgIsletmeler_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="No" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="İşletme Adı" Binding="{Binding IsletmeAdi}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Adres" Binding="{Binding Adres}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
        
    </Grid>
</UserControl>
