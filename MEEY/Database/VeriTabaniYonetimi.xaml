<UserControl x:Class="MEEY.Database.VeriTabaniYonetimi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#E6FFFFFF">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Başlık -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="txtTabloBaslik" 
                      Text="Tablo Seçin" 
                      FontSize="18" 
                      FontWeight="Bold"
                      Foreground="#2C3E50"/>
            <TextBlock x:Name="txtKayitSayisi" 
                      Text="" 
                      FontSize="12" 
                      Foreground="#7F8C8D"
                      Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- DataGrid -->
        <Border Grid.Row="1"
                CornerRadius="10"
                Background="#E6F8F9FA"
                BorderBrush="#BDC3C7"
                BorderThickness="1"
                Padding="2">
            <DataGrid x:Name="dgVeriTabani" 
                     AutoGenerateColumns="True"
                     CanUserAddRows="False"
                     IsReadOnly="True"
                     AlternatingRowBackground="#F8F9FA"
                     GridLinesVisibility="All"
                     HeadersVisibility="All"/>
        </Border>
        
    </Grid>
</UserControl>
