<UserControl x:Class="MEEY.DigerEvraklar.DigerEvraklarBase"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="White"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Üst Bar: Başlık + Arama + Klasör Aç -->
        <Border Grid.Row="0" Background="#E74C3C" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Koordinatörlük Evrakları" 
                           FontSize="18" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="txtArama" Width="220" Height="30" 
                             Padding="8,4" FontSize="12"
                             VerticalContentAlignment="Center"
                             TextChanged="txtArama_TextChanged"/>
                    <Button x:Name="btnKlasorAc" Content="Klasoru Ac" 
                            Height="30" Margin="8,0,0,0" Padding="10,0"
                            Background="White" Foreground="#E74C3C"
                            BorderThickness="0" FontWeight="Bold" FontSize="12"
                            Cursor="Hand" Click="btnKlasorAc_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- İstatistik Bar -->
        <Border Grid.Row="1" Background="#FDEDEC" Padding="16,6" 
                BorderBrush="#F5B7B1" BorderThickness="0,0,0,1">
            <TextBlock x:Name="lblDosyaSayisi" FontSize="11" Foreground="#922B21"/>
        </Border>

        <!-- Dosya Listesi -->
        <ListView x:Name="lvDosyalar" Grid.Row="2"
                  BorderThickness="0"
                  Background="White"
                  SelectionMode="Single"
                  MouseDoubleClick="lvDosyalar_MouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#EEEEEE"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FEF9F9"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FADBD8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="12,8" ToolTip="{Binding FullPath}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <!-- Renkli Rozet -->
                        <Border Background="{Binding RozetRenk}" 
                                CornerRadius="4" Width="42" Height="28"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding RozetMetin}" 
                                       Foreground="White" FontWeight="Bold"
                                       FontSize="11" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        </Border>

                        <!-- İsim + tür -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding Baslik}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#1A1A1A" TextTrimming="CharacterEllipsis"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding UzantiBilgisi}" FontSize="10" 
                                       Foreground="#999" FontFamily="Segoe UI"/>
                        </StackPanel>

                        <!-- Boyut -->
                        <TextBlock Grid.Column="2" Text="{Binding Boyut}" FontSize="11"
                                   Foreground="#AAA" VerticalAlignment="Center" 
                                   TextAlignment="Right" Margin="0,0,12,0"
                                   FontFamily="Segoe UI"/>

                        <!-- Aç butonu -->
                        <Button Grid.Column="3" Content="Ac" Height="26" Padding="8,0"
                                Background="#E74C3C" Foreground="White" BorderThickness="0"
                                FontSize="11" FontWeight="Bold" Cursor="Hand"
                                Tag="{Binding FullPath}" Click="BtnAc_Click"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
